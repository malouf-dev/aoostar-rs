# Mapping sensor labels from sensor value providers to panel definition labels.
#
# Template for the Docker container: @NET_IF@ is replaced by the entrypoint
# with the detected (or NET_INTERFACE-configured) network interface.
#
# Key = label identifier used in panel definition
# Value = label identifier used in sensor providers

cpu_percent: cpu_usage_percent
cpu_temperature: temperature_cpu
memory_usage: mem_usage_percent
memory_Temperature: temperature_memory
gpu_temperature: temperature_gpu
gpu_core: gpu_usage_percent
motherboard_temperature: temperature_motherboard

net_upload_speed: network_@NET_IF@_upload_speed
net_download_speed: network_@NET_IF@_download_speed
net_ip_address: network_@NET_IF@_address0

# NVMe drives (requires DISK_REFRESH; temperatures require SMARTCTL=1)
storage_ssd[0]['used']: storage_ssd[0]_usage_percent
storage_ssd[0]['temperature']: storage_ssd[0]_temperature
storage_ssd[1]['used']: storage_ssd[1]_usage_percent
storage_ssd[1]['temperature']: storage_ssd[1]_temperature
storage_ssd[2]['used']: storage_ssd[2]_usage_percent
storage_ssd[2]['temperature']: storage_ssd[2]_temperature
storage_ssd[3]['used']: storage_ssd[3]_usage_percent
storage_ssd[3]['temperature']: storage_ssd[3]_temperature
storage_ssd[4]['used']: storage_ssd[4]_usage_percent
storage_ssd[4]['temperature']: storage_ssd[4]_temperature

# SATA/USB drives in the HD bays
storage_hdd[0]['used']: storage_hdd[0]_usage_percent
storage_hdd[0]['temperature']: storage_hdd[0]_temperature
storage_hdd[1]['used']: storage_hdd[1]_usage_percent
storage_hdd[1]['temperature']: storage_hdd[1]_temperature
storage_hdd[2]['used']: storage_hdd[2]_usage_percent
storage_hdd[2]['temperature']: storage_hdd[2]_temperature
storage_hdd[3]['used']: storage_hdd[3]_usage_percent
storage_hdd[3]['temperature']: storage_hdd[3]_temperature
storage_hdd[4]['used']: storage_hdd[4]_usage_percent
storage_hdd[4]['temperature']: storage_hdd[4]_temperature
storage_hdd[5]['used']: storage_hdd[5]_usage_percent
storage_hdd[5]['temperature']: storage_hdd[5]_temperature
